<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ea580c" />
    <meta name="description" content="Invoice details and download" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/app-icon.svg" />
    <title>Invoice <%= order.invoiceNumber %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/pwa-install.js"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: "#fff7ed",
                100: "#ffedd5",
                500: "#f97316",
                600: "#ea580c"
              }
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-gradient-to-b from-white to-brand-50 text-zinc-800">
    <% const formatRP = (n) => `RP ${Number(n || 0).toLocaleString('en-US')}`; %>

    <main class="mx-auto max-w-4xl px-4 py-6 md:px-6">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2 print:hidden">
        <div class="flex gap-2">
          <a href="/invoices-orders" class="rounded-xl border border-orange-200 bg-white px-4 py-3 font-semibold hover:bg-orange-50">📋 Back to Invoices</a>
          <a href="/" class="rounded-xl border border-orange-200 bg-white px-4 py-3 font-semibold hover:bg-orange-50">🏠 Home</a>
        </div>
        <button onclick="window.print()" class="rounded-xl bg-brand-500 px-4 py-3 font-bold text-white hover:bg-brand-600">Print Invoice</button>
      </div>

      <section class="rounded-2xl border border-orange-100 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3 border-b border-orange-100 pb-4">
          <div>
            <h1 class="text-2xl font-extrabold text-brand-600">Purchase Invoice</h1>
            <p class="text-sm text-zinc-500">Invoice Number: <%= order.invoiceNumber %></p>
          </div>
          <div class="text-sm">
            <p>Customer: <span class="font-bold"><%= order.customerName %></span></p>
            <p>Status: <span class="font-bold <%= order.status === 'completed' ? 'text-emerald-600' : 'text-amber-600' %>"><%= order.status === "completed" ? "Completed" : "Pending" %></span></p>
            <p>Date: <%= new Date(order.createdAt).toLocaleString("en-US") %></p>
          </div>
        </div>

        <div class="mt-4 overflow-auto rounded-xl border border-orange-100">
          <table class="w-full text-sm">
            <thead class="bg-orange-50">
              <tr>
                <th class="p-3 text-left">Product</th>
                <th class="p-3 text-left">Unit Price</th>
                <th class="p-3 text-left">Quantity</th>
                <th class="p-3 text-left">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% order.items.forEach((item) => { %>
              <tr class="border-t border-orange-100">
                <td class="p-3"><%= item.name %></td>
                <td class="p-3"><%= formatRP(item.unitPrice) %></td>
                <td class="p-3"><%= item.quantity %></td>
                <td class="p-3"><%= formatRP(item.subtotal) %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="mt-4 flex justify-end">
          <div class="rounded-xl bg-orange-50 px-4 py-3 text-lg font-extrabold text-brand-600">Grand Total: <%= formatRP(order.total) %></div>
        </div>
      </section>
    </main>

    <script>
      if (window.PWAInstall) {
        window.PWAInstall.bindInstallButton('#installPwaBtn');
      }
    </script>
  </body>
</html>
