<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: "#fff7ed",
                100: "#ffedd5",
                500: "#f97316",
                600: "#ea580c"
              }
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-gradient-to-b from-white to-brand-50 text-zinc-800">
    <% const formatRP = (n) => `RP ${Number(n || 0).toLocaleString('en-US')}`; %>

    <header class="border-b border-orange-100 bg-white">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-4 md:px-6">
        <div>
          <h1 class="text-2xl font-extrabold text-brand-600">Admin Panel</h1>
          <p class="text-sm text-zinc-500">Signed in as <span class="font-semibold"><%= user.name %></span></p>
        </div>
        <a href="/" class="rounded-xl border border-orange-200 px-4 py-3 text-sm font-semibold hover:bg-orange-50">Back to Store</a>
      </div>
    </header>

    <main class="mx-auto max-w-7xl space-y-6 px-4 py-6 md:px-6">
      <nav class="overflow-x-auto">
        <div class="flex w-max gap-2 rounded-2xl border border-orange-100 bg-white p-2">
          <a href="/admin?tab=forms" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'forms' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Forms</a>
          <a href="/admin?tab=products" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'products' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Products</a>
          <a href="/admin?tab=invoices" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'invoices' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Invoices</a>
          <a href="/admin?tab=pending" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'pending' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Pending Orders</a>
        </div>
      </nav>

      <% if (tab === 'forms') { %>
      <section class="grid gap-6 lg:grid-cols-2">
        <article class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
          <h2 class="text-xl font-bold">Add Product</h2>
          <form method="post" action="/admin/products" class="mt-4 space-y-3">
            <input name="name" type="text" placeholder="Product name" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <input name="price" type="number" min="1" placeholder="Price" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <input name="quantity" type="number" min="0" placeholder="Quantity (units in stock)" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <input name="image" type="url" placeholder="Image URL (optional)" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" />
            <button class="w-full rounded-xl bg-brand-500 px-4 py-3 text-base font-bold text-white hover:bg-brand-600">Save Product</button>
          </form>
        </article>

        <article class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
          <h2 class="text-xl font-bold">Add User Name</h2>
          <form method="post" action="/admin/customers" class="mt-4 space-y-3">
            <input name="name" type="text" placeholder="User name" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <label class="flex items-center gap-2 rounded-xl border border-orange-100 bg-orange-50/60 px-4 py-3 text-sm">
              <input name="isAdmin" type="checkbox" class="h-4 w-4" />
              Grant admin access
            </label>
            <button class="w-full rounded-xl bg-zinc-900 px-4 py-3 text-base font-bold text-white">Add User</button>
          </form>

          <div class="mt-5 max-h-72 overflow-auto rounded-xl border border-orange-100">
            <table class="w-full text-sm">
              <thead class="bg-orange-50">
                <tr>
                  <th class="p-3 text-left">Name</th>
                  <th class="p-3 text-left">Role</th>
                </tr>
              </thead>
              <tbody>
                <% customers.forEach((c) => { %>
                <tr class="border-t border-orange-100">
                  <td class="p-3"><%= c.name %></td>
                  <td class="p-3"><%= c.isAdmin ? 'Admin' : 'Customer' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </article>
      </section>
      <% } %>

      <% if (tab === 'products') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Manage Products</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          <% if (products.length === 0) { %>
          <p class="text-zinc-500">No products yet.</p>
          <% } %>
          <% products.forEach((p) => { %>
          <article class="rounded-xl border border-orange-100 bg-orange-50/40 p-3">
            <img src="<%= p.image || '/default-product.svg' %>" alt="<%= p.name %>" class="h-40 w-full rounded-lg object-cover" />
            <form method="post" action="/admin/products/<%= p._id %>/update" class="mt-3 space-y-2">
              <input name="name" value="<%= p.name %>" type="text" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" required />
              <input name="price" value="<%= p.price %>" type="number" min="1" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" required />
              <input name="quantity" value="<%= p.quantity || 0 %>" type="number" min="0" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" required />
              <input name="image" value="<%= p.image %>" type="url" placeholder="Image URL (optional)" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" />
              <button class="w-full rounded-lg bg-brand-500 px-3 py-3 text-sm font-bold text-white hover:bg-brand-600">Update Product</button>
            </form>
            <form method="post" action="/admin/products/<%= p._id %>/delete" class="mt-2" onsubmit="return confirm('Delete this product?')">
              <button class="w-full rounded-lg bg-red-600 px-3 py-3 text-sm font-bold text-white">Delete Product</button>
            </form>
          </article>
          <% }) %>
        </div>
      </section>
      <% } %>

      <% if (tab === 'invoices') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Purchased Products & Invoices</h2>
        <div class="mt-4 overflow-auto rounded-xl border border-orange-100">
          <table class="w-full min-w-[760px] text-sm">
            <thead class="bg-orange-50">
              <tr>
                <th class="p-3 text-left">Customer</th>
                <th class="p-3 text-left">Product</th>
                <th class="p-3 text-left">Qty</th>
                <th class="p-3 text-left">Subtotal</th>
                <th class="p-3 text-left">Invoice</th>
                <th class="p-3 text-left">Status</th>
                <th class="p-3 text-left">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (purchasedRows.length === 0) { %>
              <tr>
                <td class="p-4 text-zinc-500" colspan="7">No purchases yet.</td>
              </tr>
              <% } %>
              <% purchasedRows.forEach((row) => { %>
              <tr class="border-t border-orange-100">
                <td class="p-3"><%= row.customerName %></td>
                <td class="p-3"><%= row.productName %></td>
                <td class="p-3"><%= row.quantity %></td>
                <td class="p-3"><%= formatRP(row.subtotal) %></td>
                <td class="p-3"><%= row.invoiceNumber %></td>
                <td class="p-3">
                  <span class="font-semibold <%= row.status === 'completed' ? 'text-emerald-600' : 'text-amber-600' %>"><%= row.status === 'completed' ? 'Completed' : 'Pending' %></span>
                </td>
                <td class="p-3"><a href="/invoices/<%= row.invoiceNumber %>" class="font-semibold text-brand-600 hover:underline">View</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
      <% } %>

      <% if (tab === 'pending') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Pending Orders</h2>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          <% if (pendingOrders.length === 0) { %>
          <p class="text-zinc-500">No pending orders.</p>
          <% } %>
          <% pendingOrders.forEach((order) => { %>
          <article class="rounded-xl border border-orange-100 bg-orange-50/40 p-4">
            <p class="font-semibold"><%= order.customerName %></p>
            <p class="text-sm text-zinc-600">Invoice: <%= order.invoiceNumber %></p>
            <p class="mt-1 text-sm">Total: <span class="font-bold"><%= formatRP(order.total) %></span></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <form method="post" action="/admin/orders/<%= order._id %>/complete">
                <button class="rounded-lg bg-emerald-600 px-4 py-3 text-xs font-bold text-white">Mark Completed</button>
              </form>
              <a href="/invoices/<%= order.invoiceNumber %>" class="rounded-lg border border-orange-200 bg-white px-4 py-3 text-xs font-bold text-brand-600">View Invoice</a>
            </div>
          </article>
          <% }) %>
        </div>
      </section>
      <% } %>
    </main>
  </body>
</html>
