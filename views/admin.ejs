<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: "#fff7ed",
                100: "#ffedd5",
                500: "#f97316",
                600: "#ea580c"
              }
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-gradient-to-b from-white to-brand-50 text-zinc-800">
    <% const formatRP = (n) => `RP ${Number(n || 0).toLocaleString('en-US')}`; %>

    <header class="border-b border-orange-100 bg-white">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-4 md:px-6">
        <div>
          <h1 class="text-2xl font-extrabold text-brand-600">Admin Panel</h1>
          <p class="text-sm text-zinc-500">Signed in as <span class="font-semibold"><%= user.name %></span></p>
        </div>
        <a href="/" class="rounded-xl border border-orange-200 px-4 py-3 text-sm font-semibold hover:bg-orange-50">Back to Store</a>
      </div>
    </header>

    <main class="mx-auto max-w-7xl space-y-6 px-4 py-6 md:px-6">
      <nav class="overflow-x-auto">
        <div class="flex w-max gap-2 rounded-2xl border border-orange-100 bg-white p-2">
          <a href="/admin?tab=forms" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'forms' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Forms</a>
          <a href="/admin?tab=products" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'products' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Products</a>
          <a href="/admin?tab=invoices" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'invoices' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Invoices</a>
          <a href="/admin?tab=pending" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'pending' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Pending Orders</a>
          <a href="/admin?tab=process" class="rounded-xl px-4 py-3 text-sm font-semibold <%= tab === 'process' ? 'bg-brand-500 text-white' : 'bg-orange-50 text-zinc-700 hover:bg-orange-100' %>">Processing Orders</a>
        </div>
      </nav>

      <% if (tab === 'forms') { %>
      <section class="grid gap-6 lg:grid-cols-2">
        <article class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
          <h2 class="text-xl font-bold">Add Product</h2>
          <form method="post" action="/admin/products" class="mt-4 space-y-3">
            <input name="name" type="text" placeholder="Product name" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <input name="category" type="text" placeholder="Category (e.g., Vegetables, Sauces)" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" />
            <input name="price" type="number" min="1" placeholder="Price" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <input name="quantity" type="number" min="0" placeholder="Quantity (units in stock)" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <input name="image" type="url" placeholder="Image URL (optional)" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" />
            <label class="flex items-center gap-2 rounded-xl border border-orange-100 bg-orange-50/60 px-4 py-3 text-sm">
              <input name="isEditable" type="checkbox" class="h-4 w-4" />
              <span class="font-semibold text-zinc-700">Allow users to edit this product</span>
            </label>
            <button class="w-full rounded-xl bg-brand-500 px-4 py-3 text-base font-bold text-white hover:bg-brand-600">Save Product</button>
          </form>
        </article>

        <article class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
          <h2 class="text-xl font-bold">Add User Name</h2>
          <form method="post" action="/admin/customers" class="mt-4 space-y-3">
            <input name="name" type="text" placeholder="User name" class="w-full rounded-xl border border-orange-200 px-4 py-3 text-base" required />
            <label class="flex items-center gap-2 rounded-xl border border-orange-100 bg-orange-50/60 px-4 py-3 text-sm">
              <input name="isAdmin" type="checkbox" class="h-4 w-4" />
              Grant admin access
            </label>
            <button class="w-full rounded-xl bg-zinc-900 px-4 py-3 text-base font-bold text-white">Add User</button>
          </form>

          <div class="mt-5 max-h-72 overflow-auto rounded-xl border border-orange-100">
            <table class="w-full text-sm">
              <thead class="bg-orange-50">
                <tr>
                  <th class="p-3 text-left">Name</th>
                  <th class="p-3 text-left">Role</th>
                </tr>
              </thead>
              <tbody>
                <% customers.forEach((c) => { %>
                <tr class="border-t border-orange-100">
                  <td class="p-3"><%= c.name %></td>
                  <td class="p-3"><%= c.isAdmin ? 'Admin' : 'Customer' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </article>
      </section>
      <% } %>

      <% if (tab === 'products') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Manage Products</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          <% if (products.length === 0) { %>
          <p class="text-zinc-500">No products yet.</p>
          <% } %>
          <% products.forEach((p) => { %>
          <article class="rounded-xl border border-orange-100 bg-orange-50/40 p-3">
            <img src="<%= p.image || '/default-product.svg' %>" alt="<%= p.name %>" class="h-40 w-full rounded-lg object-cover" />
            <form method="post" action="/admin/products/<%= p._id %>/update" class="mt-3 space-y-2">
              <input name="name" value="<%= p.name %>" type="text" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" required />
              <input name="category" value="<%= p.category || 'General' %>" type="text" placeholder="Category" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" />
              <input name="price" value="<%= p.price %>" type="number" min="1" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" required />
              <input name="quantity" value="<%= p.quantity || 0 %>" type="number" min="0" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" required />
              <input name="image" value="<%= p.image %>" type="url" placeholder="Image URL (optional)" class="w-full rounded-lg border border-orange-200 bg-white px-3 py-2" />
              <label class="flex items-center gap-2 rounded-lg border border-orange-200 bg-white px-3 py-3">
                <input type="checkbox" name="isEditable" <%= p.isEditable ? 'checked' : '' %> class="h-4 w-4 rounded" />
                <span class="text-sm font-semibold text-zinc-700">Allow users to edit this product</span>
              </label>
              <button class="w-full rounded-lg bg-brand-500 px-3 py-3 text-sm font-bold text-white hover:bg-brand-600">Update Product</button>
            </form>
            <form method="post" action="/admin/products/<%= p._id %>/delete" class="mt-2" onsubmit="return confirm('Delete this product?')">
              <button class="w-full rounded-lg bg-red-600 px-3 py-3 text-sm font-bold text-white">Delete Product</button>
            </form>
          </article>
          <% }) %>
        </div>
      </section>
      <% } %>

      <% if (tab === 'invoices') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Purchased Products & Invoices</h2>
        <div class="mt-4 overflow-auto rounded-xl border border-orange-100">
          <table class="w-full min-w-[760px] text-sm">
            <thead class="bg-orange-50">
              <tr>
                <th class="p-3 text-left">Customer</th>
                <th class="p-3 text-left">Product</th>
                <th class="p-3 text-left">Qty</th>
                <th class="p-3 text-left">Subtotal</th>
                <th class="p-3 text-left">Invoice</th>
                <th class="p-3 text-left">Status</th>
                <th class="p-3 text-left">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (purchasedRows.length === 0) { %>
              <tr>
                <td class="p-4 text-zinc-500" colspan="7">No purchases yet.</td>
              </tr>
              <% } %>
              <% purchasedRows.forEach((row) => { %>
              <tr class="border-t border-orange-100">
                <td class="p-3"><%= row.customerName %></td>
                <td class="p-3"><%= row.productName %></td>
                <td class="p-3"><%= row.quantity %></td>
                <td class="p-3"><%= formatRP(row.subtotal) %></td>
                <td class="p-3"><%= row.invoiceNumber %></td>
                <td class="p-3">
                  <span class="font-semibold <%= row.status === 'completed' ? 'text-emerald-600' : 'text-amber-600' %>"><%= row.status === 'completed' ? 'Completed' : 'Pending' %></span>
                </td>
                <td class="p-3"><a href="/invoices/<%= row.invoiceNumber %>" class="font-semibold text-brand-600 hover:underline">View</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
      <% } %>

      <% if (tab === 'pending') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Pending Orders</h2>
        <div class="mt-4 space-y-4">
          <% const pendingOnly = pendingOrders.filter(o => o.status === 'pending'); %>
          <% if (pendingOnly.length === 0) { %>
          <p class="text-zinc-500">No pending orders.</p>
          <% } %>
          <% pendingOnly.forEach((order) => { %>
          <article class="rounded-xl border border-amber-200 bg-amber-50/40 p-4">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-lg font-bold"><%= order.customerName %></p>
              <span class="rounded-lg bg-amber-100 px-3 py-1 text-sm font-bold text-amber-700">⏳ Pending</span>
            </div>
            <p class="mb-3 text-sm text-zinc-600">Invoice: <span class="font-semibold text-brand-600"><%= order.invoiceNumber %></span> | Total: <span class="font-bold"><%= formatRP(order.total) %></span></p>
            <div class="flex gap-2">
              <button type="button" class="start-process-btn rounded-lg bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-700" data-order-id="<%= order._id %>">Start Processing →</button>
              <a href="/invoices/<%= order.invoiceNumber %>" class="rounded-lg border border-orange-200 bg-white px-4 py-2 text-sm font-semibold text-brand-600 hover:bg-orange-50">View Invoice</a>
            </div>
          </article>
          <% }) %>
        </div>
      </section>
      <% } %>

      <% if (tab === 'process') { %>
      <section class="rounded-2xl border border-orange-100 bg-white p-5 shadow-sm md:p-6">
        <h2 class="text-xl font-bold">Processing Orders - Edit & Manage</h2>
        <div class="mt-4 space-y-4">
          <% const processOrders = pendingOrders.filter(o => o.status === 'process'); %>
          <% if (processOrders.length === 0) { %>
          <p class="text-zinc-500">No orders in processing. Go to Pending Orders and click "Start Processing" to begin.</p>
          <% } %>
          <% processOrders.forEach((order) => { %>
          <article class="rounded-xl border border-blue-200 bg-blue-50/40 p-4">
            <div class="mb-4 border-b border-blue-100 pb-3">
              <p class="text-lg font-bold"><%= order.customerName %></p>
              <div class="mt-1 flex flex-wrap items-center gap-4 text-sm">
                <span class="font-semibold text-brand-600">Invoice: <%= order.invoiceNumber %></span>
                <span class="rounded-lg bg-blue-100 px-3 py-1 font-bold text-blue-700">⚙️ Processing</span>
              </div>
            </div>

            <div class="overflow-auto rounded-lg border border-blue-100">
              <table class="w-full text-sm">
                <thead class="bg-blue-50">
                  <tr>
                    <th class="p-2 text-left">Product</th>
                    <th class="p-2 text-left">Price</th>
                    <th class="p-2 text-left">Qty</th>
                    <th class="p-2 text-left">Subtotal</th>
                    <th class="p-2 text-left">Status</th>
                    <th class="p-2 text-left">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% order.items.forEach((item, idx) => { %>
                  <tr class="border-t border-blue-100">
                    <td class="p-2 font-semibold"><%= item.name %></td>
                    <td class="p-2">
                      <span class="item-price-<%= order._id %>-<%= idx %>"><%= formatRP(item.unitPrice) %></span>
                    </td>
                    <td class="p-2">
                      <span class="item-qty-<%= order._id %>-<%= idx %>"><%= item.quantity %></span>
                    </td>
                    <td class="p-2 font-semibold">
                      <span class="item-subtotal-<%= order._id %>-<%= idx %>"><%= formatRP(item.subtotal) %></span>
                    </td>
                    <td class="p-2">
                      <span class="item-status-<%= order._id %>-<%= idx %> rounded-lg px-2 py-1 text-xs font-bold <%= item.itemStatus === 'completed' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                        <%= item.itemStatus === 'completed' ? '✓ Done' : '⏳ Pending' %>
                      </span>
                    </td>
                    <td class="p-2">
                      <div class="flex flex-wrap gap-1">
                        <button type="button" class="edit-price-btn rounded bg-blue-100 px-2 py-1 text-xs font-semibold text-blue-700 hover:bg-blue-200" data-order="<%= order._id %>" data-index="<%= idx %>" data-current-price="<%= item.unitPrice %>" title="Edit Price">💰</button>
                        <button type="button" class="edit-qty-btn rounded bg-cyan-100 px-2 py-1 text-xs font-semibold text-cyan-700 hover:bg-cyan-200" data-order="<%= order._id %>" data-index="<%= idx %>" data-current-qty="<%= item.quantity %>" title="Edit Quantity">📦</button>
                        <% if (item.itemStatus === 'pending') { %>
                        <button type="button" class="complete-item-btn rounded bg-emerald-100 px-2 py-1 text-xs font-semibold text-emerald-700 hover:bg-emerald-200" data-order="<%= order._id %>" data-index="<%= idx %>" title="Mark Completed">✓</button>
                        <% } else { %>
                        <button type="button" class="revert-item-btn rounded bg-gray-100 px-2 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-200" data-order="<%= order._id %>" data-index="<%= idx %>" title="Revert to Pending">↺</button>
                        <% } %>
                        <button type="button" class="delete-item-btn rounded bg-red-100 px-2 py-1 text-xs font-semibold text-red-700 hover:bg-red-200" data-order="<%= order._id %>" data-index="<%= idx %>" title="Delete Product">🗑️</button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <div class="mt-4 flex items-center justify-between">
              <p class="text-lg font-bold">Total: <span class="text-brand-600 order-total-<%= order._id %>"><%= formatRP(order.total) %></span></p>
              <div class="flex gap-2">
                <button type="button" class="mark-completed-btn rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700" data-order="<%= order._id %>">✓ Mark All Completed</button>
                <a href="/admin?tab=pending" class="rounded-lg border border-orange-200 bg-white px-4 py-2 text-sm font-semibold text-brand-600 hover:bg-orange-50">← Back</a>
              </div>
            </div>
          </article>
          <% }) %>
        </div>
      </section>
      <% } %>
    </main>

    <script>
      const formatRP = (n) => `RP ${Number(n || 0).toLocaleString('en-US')}`;

      // Start processing order
      document.querySelectorAll('.start-process-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const orderId = button.dataset.orderId;
          
          if (!confirm('Start processing this order?')) return;
          
          fetch(`/admin/orders/${orderId}/start-process`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              window.location.href = '/admin?tab=process';
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error starting process: ' + err.message);
          });
        });
      });

      // Edit item price
      document.querySelectorAll('.edit-price-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const orderId = button.dataset.order;
          const itemIndex = button.dataset.index;
          const currentPrice = button.dataset.currentPrice;
          
          const newPrice = prompt(`Enter new unit price (current: ${formatRP(currentPrice)}):`, currentPrice);
          if (newPrice === null || newPrice === '') return;
          
          const price = Number(newPrice);
          if (isNaN(price) || price <= 0) {
            alert('Invalid price. Please enter a valid number.');
            return;
          }
          
          fetch(`/admin/orders/${orderId}/items/${itemIndex}/price`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ unitPrice: price })
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              document.querySelector(`.item-price-${orderId}-${itemIndex}`).textContent = formatRP(data.newPrice);
              document.querySelector(`.item-subtotal-${orderId}-${itemIndex}`).textContent = formatRP(data.newSubtotal);
              document.querySelector(`.order-total-${orderId}`).textContent = formatRP(data.newTotal);
              alert('Price updated successfully!');
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error updating price: ' + err.message);
          });
        });
      });

      // Edit item quantity
      document.querySelectorAll('.edit-qty-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const orderId = button.dataset.order;
          const itemIndex = button.dataset.index;
          const currentQty = button.dataset.currentQty;
          
          const newQty = prompt(`Enter new quantity (current: ${currentQty}):`, currentQty);
          if (newQty === null || newQty === '') return;
          
          const qty = Number(newQty);
          if (isNaN(qty) || qty <= 0) {
            alert('Invalid quantity. Please enter a valid number.');
            return;
          }
          
          fetch(`/admin/orders/${orderId}/items/${itemIndex}/quantity`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ quantity: qty })
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              document.querySelector(`.item-qty-${orderId}-${itemIndex}`).textContent = data.newQuantity;
              document.querySelector(`.item-subtotal-${orderId}-${itemIndex}`).textContent = formatRP(data.newSubtotal);
              document.querySelector(`.order-total-${orderId}`).textContent = formatRP(data.newTotal);
              alert('Quantity updated successfully!');
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error updating quantity: ' + err.message);
          });
        });
      });

      // Complete individual item
      document.querySelectorAll('.complete-item-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const orderId = button.dataset.order;
          const itemIndex = button.dataset.index;
          
          fetch(`/admin/orders/${orderId}/items/${itemIndex}/complete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              location.reload();
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error completing item: ' + err.message);
          });
        });
      });

      // Revert item to pending
      document.querySelectorAll('.revert-item-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const orderId = button.dataset.order;
          const itemIndex = button.dataset.index;
          
          fetch(`/admin/orders/${orderId}/items/${itemIndex}/pending`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              location.reload();
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error reverting item: ' + err.message);
          });
        });
      });

      // Delete item from order
      document.querySelectorAll('.delete-item-btn').forEach((button) => {
        button.addEventListener('click', () => {
          if (!confirm('Are you sure you want to delete this product?')) return;
          
          const orderId = button.dataset.order;
          const itemIndex = button.dataset.index;
          
          fetch(`/admin/orders/${orderId}/items/${itemIndex}/delete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              location.reload();
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error deleting item: ' + err.message);
          });
        });
      });

      // Mark all items as completed
      document.querySelectorAll('.mark-completed-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const orderId = button.dataset.order;
          
          fetch(`/admin/orders/${orderId}/complete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(res => {
            if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
            return res.json();
          })
          .then(data => {
            if (data.success) {
              location.reload();
            } else {
              alert('Error: ' + (data.error || 'Unknown error'));
            }
          })
          .catch(err => {
            console.error('Fetch error:', err);
            alert('Error marking order as completed: ' + err.message);
          });
        });
      });
    </script>
  </body>
</html>
