<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: "#fff7ed",
                100: "#ffedd5",
                500: "#f97316",
                600: "#ea580c"
              }
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-white text-zinc-800">
    <% const formatRP = (n) => `RP ${Number(n || 0).toLocaleString('en-US')}`; %>

    <!-- Header -->
    <header class="sticky top-0 z-30 border-b border-zinc-200 bg-white/98 backdrop-blur">
      <div class="mx-auto flex w-full items-center justify-between gap-4 px-4 py-3 md:px-6 md:py-4">
        <div class="flex items-center gap-3">
          <div class="rounded-lg bg-brand-500 px-3 py-2 text-white font-bold text-lg">🍜</div>
          <div>
            <h1 class="text-xl font-extrabold text-zinc-900">Market Shawarma</h1>
            <p class="text-xs text-zinc-500">Welcome back, <%= user.name %></p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <button id="installPwaBtn" type="button" class="hidden rounded-lg bg-blue-600 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-700">
            📥 Install
          </button>
          <button onclick="openManualOrderModal()" class="rounded-lg border border-brand-200 bg-brand-50 px-3 py-2 text-xs font-semibold text-brand-600 hover:bg-brand-100">✏️ Manual Order</button>
          <a href="/invoices-orders" class="rounded-lg border border-brand-200 bg-brand-50 px-3 py-2 text-xs font-semibold text-brand-600 hover:bg-brand-100">📋 Orders</a>
          <% if (user.isAdmin) { %>
          <a href="/admin" class="rounded-lg border border-zinc-200 px-3 py-2 text-xs font-semibold hover:bg-zinc-100">⚙️ Admin</a>
          <% } %>
          <form method="post" action="/logout" class="contents">
            <button class="rounded-lg border border-zinc-200 px-3 py-2 text-xs font-semibold hover:bg-zinc-100">🚪 Exit</button>
          </form>
        </div>
      </div>
    </header>

    <!-- Main Layout -->
    <main class="flex h-screen flex-col overflow-hidden">
      <!-- Products & Cart Grid -->
      <div class="flex flex-1 gap-0 overflow-hidden">
        <!-- Products Section -->
        <section class="flex-1 overflow-y-auto bg-zinc-50">
          <!-- Category Buttons -->
          <% if (categories && categories.length > 0) { %>
          <div class="sticky top-0 z-10 border-b border-zinc-200 bg-white p-4 md:p-6">
            <div class="flex flex-wrap gap-2">
              <button class="category-btn px-4 py-2 rounded-full text-sm font-semibold border-2 transition" data-category="all">
                📦 All Products
              </button>
              <% categories.forEach(cat => { %>
              <button class="category-btn px-4 py-2 rounded-full text-sm font-semibold border-2 transition" data-category="<%= cat %>">
                <%= cat %>
              </button>
              <% }) %>
            </div>
          </div>
          <% } %>

          <div class="grid gap-3 p-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 md:p-6">
            <% if (products.length === 0) { %>
            <div class="col-span-full rounded-lg border-2 border-dashed border-zinc-300 bg-white p-8 text-center text-zinc-500">
              <p class="text-sm">📦 No products available yet</p>
            </div>
            <% } %>

            <% products.forEach((product) => { %>
            <article class="product-card group overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm transition hover:shadow-md cursor-pointer" data-product-id="<%= product._id %>" data-product-name="<%= product.name %>" data-product-image="<%= product.image %>" data-product-price="<%= product.price %>" data-product-category="<%= product.category || 'General' %>">
              <div class="relative h-40 overflow-hidden bg-zinc-100" onclick="openProductModal(this.parentElement.dataset.productId, this.parentElement.dataset.productName, this.parentElement.dataset.productImage, parseFloat(this.parentElement.dataset.productPrice))">
                <img src="<%= product.image || '/default-product.svg' %>" alt="<%= product.name %>" class="h-full w-full object-cover transition group-hover:scale-105" />
              </div>
              <div class="p-3" onclick="openProductModal(this.parentElement.dataset.productId, this.parentElement.dataset.productName, this.parentElement.dataset.productImage, parseFloat(this.parentElement.dataset.productPrice))">
                <h3 class="text-sm font-bold text-zinc-900 line-clamp-2"><%= product.name %></h3>
                <p class="mt-2 text-base font-extrabold text-brand-600"><%= formatRP(product.price) %></p>
              </div>
            </article>
            <% }) %>
          </div>
        </section>

        <!-- Cart Sidebar -->
        <aside class="w-80 flex-shrink-0 border-l border-zinc-200 bg-white p-4 md:p-6 flex flex-col overflow-hidden">
          <div class="mb-4">
            <h2 class="text-lg font-bold text-zinc-900">🛒 Order Cart</h2>
            <p class="text-xs text-zinc-500">Add items to get started</p>
          </div>

          <!-- Cart Items -->
          <div id="cartItems" class="flex-1 space-y-2 overflow-y-auto pr-2"></div>

          <!-- Cart Summary -->
          <div class="mt-4 space-y-3 border-t border-zinc-200 pt-3">
            <div class="flex items-center justify-between text-sm">
              <span class="text-zinc-600">Subtotal:</span>
              <span class="font-semibold text-zinc-900" id="cartSubtotal">RP 0</span>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-zinc-600">Tax (0%):</span>
              <span class="font-semibold text-zinc-900" id="cartTax">RP 0</span>
            </div>
            <div class="flex items-center justify-between border-t border-zinc-200 pt-3 text-base">
              <span class="font-bold text-zinc-900">Total:</span>
              <span class="font-bold text-brand-600 text-lg" id="cartTotal">RP 0</span>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="mt-4 space-y-2 pt-3">
            <button onclick="submitOrder()" class="w-full rounded-lg bg-brand-500 px-4 py-3 text-sm font-bold text-white transition hover:bg-brand-600 active:scale-95">
              ✅ Proceed to Order
            </button>
            <button onclick="openEditOrdersModal()" class="w-full rounded-lg border border-zinc-200 px-4 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100">
              🔄 Clear Cart
            </button>
          </div>


        </aside>
      </div>
    </main>

    <!-- Product Modal -->
    <div id="productModal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4" onclick="if(event.target.id === 'productModal') closeProductModal()">
      <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full overflow-hidden">
        <!-- Product Image -->
        <div class="relative h-64 bg-zinc-100 overflow-hidden">
          <img id="modalImage" src="" alt="" class="h-full w-full object-cover" />
          <button onclick="closeProductModal()" class="absolute top-3 right-3 bg-white/90 hover:bg-white rounded-full p-2 shadow-md">
            ✕
          </button>
        </div>
        
        <!-- Product Details -->
        <div class="p-6 space-y-4">
          <h2 id="modalName" class="text-2xl font-bold text-zinc-900"></h2>
          
          <!-- Price Info -->
          <div class="bg-brand-50 rounded-lg p-4 space-y-2">
            <div class="flex justify-between items-center">
              <span class="text-zinc-600">Unit Price:</span>
              <span id="unitPrice" class="text-lg font-bold text-brand-600"></span>
            </div>
            <div class="border-t border-brand-200 pt-2 flex justify-between items-center">
              <span class="text-zinc-900 font-semibold">Total Price:</span>
              <span id="totalPrice" class="text-2xl font-extrabold text-brand-600"></span>
            </div>
          </div>
          
          <!-- Quantity Controls -->
          <div class="bg-zinc-50 rounded-lg p-4">
            <p class="text-sm text-zinc-600 mb-3 font-semibold">Quantity:</p>
            <div class="flex items-center justify-between gap-3">
              <button onclick="decreaseModalQty()" class="flex-1 rounded-lg border-2 border-brand-600 bg-white text-brand-600 py-3 text-2xl font-bold hover:bg-brand-50 transition">
                −
              </button>
              <span id="modalQty" class="flex-1 text-center text-2xl font-bold text-zinc-900 bg-white rounded-lg py-3">1</span>
              <button onclick="increaseModalQty()" class="flex-1 rounded-lg border-2 border-brand-600 bg-white text-brand-600 py-3 text-2xl font-bold hover:bg-brand-50 transition">
                +
              </button>
            </div>
          </div>
          
          <!-- Action Buttons -->
          <div class="flex gap-3 pt-2">
            <button onclick="closeProductModal()" class="flex-1 rounded-lg border border-zinc-300 px-4 py-3 font-semibold text-zinc-700 hover:bg-zinc-100 transition">
              Cancel
            </button>
            <button onclick="addFromModal()" class="flex-1 rounded-lg bg-brand-500 px-4 py-3 font-bold text-white hover:bg-brand-600 transition">
              Add to Cart
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual Order Modal -->
    <div id="manualOrderModal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4" onclick="if(event.target.id === 'manualOrderModal') closeManualOrderModal()">
      <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full overflow-hidden">
        <div class="p-6 space-y-4">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-2xl font-bold text-zinc-900">✏️ Manual Order</h2>
            <button onclick="closeManualOrderModal()" class="text-2xl font-bold text-zinc-400 hover:text-zinc-600">✕</button>
          </div>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-zinc-700 mb-1">Product Name</label>
              <input id="manualProductName" type="text" placeholder="e.g., Onions" class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-zinc-700 mb-1">Unit Price (RP)</label>
              <input id="manualProductPrice" type="number" min="1" placeholder="15000" class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-zinc-700 mb-1">Quantity</label>
              <input id="manualProductQty" type="number" min="1" value="1" placeholder="1" class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-200" />
            </div>

            <div class="bg-brand-50 rounded-lg p-4">
              <div class="flex justify-between items-center">
                <span class="text-zinc-700 font-semibold">Subtotal:</span>
                <span id="manualSubtotal" class="text-lg font-bold text-brand-600">RP 0</span>
              </div>
            </div>
          </div>

          <div class="flex gap-3 pt-4">
            <button onclick="closeManualOrderModal()" class="flex-1 rounded-lg border border-zinc-300 px-4 py-3 font-semibold text-zinc-700 hover:bg-zinc-100 transition">
              Cancel
            </button>
            <button onclick="addManualProduct()" class="flex-1 rounded-lg bg-brand-500 px-4 py-3 font-bold text-white hover:bg-brand-600 transition">
              Add Item
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Edit Orders Modal -->
    <div id="editOrdersModal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4 overflow-y-auto" onclick="if(event.target.id === 'editOrdersModal') closeEditOrdersModal()">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl my-8">
        <div class="p-6 border-b border-zinc-200">
          <div class="flex justify-between items-center">
            <h2 class="text-2xl font-bold text-zinc-900">📋 Edit Your Orders</h2>
            <button onclick="closeEditOrdersModal()" class="text-2xl font-bold text-zinc-400 hover:text-zinc-600">✕</button>
          </div>
        </div>
        
        <div class="p-6 overflow-y-auto max-h-96">
          <div id="editOrdersContent" class="space-y-4">
            <p class="text-center text-zinc-500">Loading your orders...</p>
          </div>
        </div>
      </div>
    </div>

    <script>
      const cart = new Map();
      let modalData = { productId: null, productName: null, productImage: null, productPrice: null, quantity: 1 };

      function formatRP(value) {
        return `RP ${Number(value || 0).toLocaleString("en-US")}`;
      }

      // Modal Functions
      function openProductModal(id, name, image, price) {
        modalData = { productId: id, productName: name, productImage: image, productPrice: price, quantity: 1 };
        document.getElementById('modalImage').src = image;
        document.getElementById('modalName').textContent = name;
        document.getElementById('unitPrice').textContent = formatRP(price);
        document.getElementById('modalQty').textContent = '1';
        updateModalTotal();
        document.getElementById('productModal').classList.remove('hidden');
      }

      function closeProductModal() {
        document.getElementById('productModal').classList.add('hidden');
        modalData.quantity = 1;
      }

      function increaseModalQty() {
        modalData.quantity++;
        document.getElementById('modalQty').textContent = modalData.quantity;
        updateModalTotal();
      }

      function decreaseModalQty() {
        if (modalData.quantity > 1) {
          modalData.quantity--;
          document.getElementById('modalQty').textContent = modalData.quantity;
          updateModalTotal();
        }
      }

      function updateModalTotal() {
        const total = modalData.productPrice * modalData.quantity;
        document.getElementById('totalPrice').textContent = formatRP(total);
      }

      function addFromModal() {
        const { productId, productName, productPrice, quantity } = modalData;
        const existing = cart.get(productId);
        if (existing) {
          existing.quantity += quantity;
        } else {
          cart.set(productId, { productId, name: productName, price: productPrice, quantity });
        }
        renderCart();
        closeProductModal();
      }

      function toggleQuantity(id, name, price, btn) {
        // Legacy function - not used
      }

      // Manual Order Functions
      function openManualOrderModal() {
        document.getElementById('manualProductName').value = '';
        document.getElementById('manualProductPrice').value = '';
        document.getElementById('manualProductQty').value = '1';
        updateManualSubtotal();
        document.getElementById('manualOrderModal').classList.remove('hidden');
      }

      function closeManualOrderModal() {
        document.getElementById('manualOrderModal').classList.add('hidden');
      }

      function updateManualSubtotal() {
        const price = Number(document.getElementById('manualProductPrice').value) || 0;
        const qty = Number(document.getElementById('manualProductQty').value) || 1;
        const subtotal = price * qty;
        document.getElementById('manualSubtotal').textContent = formatRP(subtotal);
      }

      document.getElementById('manualProductPrice').addEventListener('input', updateManualSubtotal);
      document.getElementById('manualProductQty').addEventListener('input', updateManualSubtotal);

      function addManualProduct() {
        const name = document.getElementById('manualProductName').value.trim();
        const price = Number(document.getElementById('manualProductPrice').value);
        const qty = Number(document.getElementById('manualProductQty').value) || 1;

        if (!name) {
          alert('Please enter product name');
          return;
        }
        if (!price || price <= 0) {
          alert('Please enter valid price');
          return;
        }

        // Generate a unique ID for manual products
        const manualId = `manual-${Date.now()}-${Math.random()}`;
        
        const existing = cart.get(manualId);
        if (existing) {
          existing.quantity += qty;
        } else {
          cart.set(manualId, { productId: manualId, name, price, quantity: qty, isManual: true });
        }
        
        renderCart();
        closeManualOrderModal();
      }

      function toggleQuantity(id, name, price, btn) {
        // Legacy function - not used
      }

      function increaseQty(id) {
        // Legacy function - not used
      }

      function decreaseQty(id) {
        // Legacy function - not used
      }

      function addToCart(id, name, price) {
        // Legacy function - not used
      }

      function renderCart() {
        const container = document.getElementById("cartItems");
        const subtotalEl = document.getElementById("cartSubtotal");
        const taxEl = document.getElementById("cartTax");
        const totalEl = document.getElementById("cartTotal");
        container.innerHTML = "";
        let subtotal = 0;

        for (const item of cart.values()) {
          const subtotalItem = item.price * item.quantity;
          const row = document.createElement("div");
          row.className = "flex items-center justify-between rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-2";
          row.innerHTML = `
            <div class="flex-1">
              <p class="text-xs font-semibold text-zinc-900">${item.name}</p>
              <p class="text-xs text-zinc-600">${item.quantity} × ${formatRP(item.price)}</p>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-bold text-brand-600">${formatRP(subtotalItem)}</span>
              <button type="button" class="rounded-md bg-red-50 px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-100" onclick="removeFromCart('${item.productId}')">✕</button>
            </div>
          `;
          container.appendChild(row);
          subtotal += subtotalItem;
        }

        if (cart.size === 0) {
          container.innerHTML = `<p class="text-xs text-zinc-500 text-center py-8">Your cart is empty</p>`;
        }

        const tax = 0;
        const total = subtotal + tax;
        subtotalEl.textContent = formatRP(subtotal);
        taxEl.textContent = formatRP(tax);
        totalEl.textContent = formatRP(total);
      }

      function removeFromCart(id) {
        cart.delete(id);
        renderCart();
      }

      function clearCart() {
        if (confirm("Clear cart?")) {
          cart.clear();
          renderCart();
        }
      }

      // Edit Orders Functions
      async function openEditOrdersModal() {
        const modal = document.getElementById('editOrdersModal');
        const content = document.getElementById('editOrdersContent');
        modal.classList.remove('hidden');
        
        try {
          const response = await fetch('/api/my-orders');
          
          if (!response.ok) {
            const error = await response.json();
            content.innerHTML = `<p class="text-center text-red-500">Error: ${error.error || 'Failed to load orders'}</p>`;
            return;
          }
          
          const orders = await response.json();
          
          if (!Array.isArray(orders)) {
            content.innerHTML = '<p class="text-center text-red-500">Invalid response format</p>';
            return;
          }
          
          const pendingOrders = orders.filter(o => o.status !== 'completed');
          
          if (pendingOrders.length === 0) {
            content.innerHTML = '<p class="text-center text-zinc-500">No pending orders to edit</p>';
            return;
          }
          
          let html = '';
          pendingOrders.forEach(order => {
            html += `
              <div class="border border-zinc-200 rounded-lg p-4 mb-4">
                <div class="mb-3">
                  <h3 class="font-bold text-zinc-900">${order.invoiceNumber}</h3>
                  <p class="text-xs text-zinc-500">Status: ${order.status}</p>
                </div>
                <div class="space-y-2">
                  ${order.items.map((item, idx) => `
                    <div class="flex items-center justify-between bg-zinc-50 p-3 rounded">
                      <div class="flex-1">
                        <p class="font-semibold text-sm">${item.name}</p>
                        <p class="text-xs text-zinc-600">${formatRP(item.unitPrice)}</p>
                      </div>
                      <div class="flex items-center gap-2">
                        <div class="flex items-center gap-1 border border-zinc-300 rounded">
                          <button onclick="updateItemQty('${order._id}', ${idx}, -1)" class="px-2 py-1 text-sm hover:bg-zinc-200">−</button>
                          <span class="px-3 py-1 text-sm font-semibold">${item.quantity}</span>
                          <button onclick="updateItemQty('${order._id}', ${idx}, 1)" class="px-2 py-1 text-sm hover:bg-zinc-200">+</button>
                        </div>
                        <input type="number" value="${item.unitPrice}" onchange="updateItemPrice('${order._id}', ${idx}, this.value)" class="w-20 px-2 py-1 text-xs border border-zinc-300 rounded" placeholder="Price" />
                      </div>
                    </div>
                  `).join('')}
                </div>
                <div class="mt-3 pt-3 border-t border-zinc-200 flex justify-end">
                  <p class="font-bold text-zinc-900">Total: ${formatRP(order.total)}</p>
                </div>
              </div>
            `;
          });
          
          content.innerHTML = html;
        } catch (error) {
          content.innerHTML = `<p class="text-center text-red-500">Error loading orders: ${error.message}</p>`;
          console.error('Error:', error);
        }
      }
      
      function closeEditOrdersModal() {
        document.getElementById('editOrdersModal').classList.add('hidden');
      }
      
      async function updateItemQty(orderId, itemIndex, change) {
        try {
          // Get current order to find current quantity
          const response = await fetch('/api/my-orders');
          const orders = await response.json();
          const order = orders.find(o => o._id === orderId);
          
          if (!order) {
            alert("Order not found");
            return;
          }
          
          const item = order.items[itemIndex];
          const newQty = item.quantity + change;
          
          if (newQty <= 0) return;
          
          const updateResponse = await fetch(`/api/orders/${orderId}/items/${itemIndex}/quantity`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ quantity: newQty })
          });
          
          if (!updateResponse.ok) {
            const error = await updateResponse.json();
            alert("Error: " + error.error);
            return;
          }
          
          if (updateResponse.ok) {
            // Add small delay to ensure server saved the data before refreshing
            await new Promise(resolve => setTimeout(resolve, 300));
            await openEditOrdersModal();
          }
        } catch (error) {
          console.error('Error updating quantity:', error);
          alert("Error updating quantity: " + error.message);
        }
      }
      
      async function updateItemPrice(orderId, itemIndex, price) {
        const newPrice = Number(price);
        if (isNaN(newPrice) || newPrice <= 0) {
          alert("Please enter a valid price");
          return;
        }
        try {
          const response = await fetch(`/api/orders/${orderId}/items/${itemIndex}/price`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ price: newPrice })
          });
          
          if (!response.ok) {
            const error = await response.json();
            alert("Error: " + error.error);
            return;
          }
          
          const result = await response.json();
          if (result.success) {
            // Add small delay to ensure server saved the data before refreshing
            await new Promise(resolve => setTimeout(resolve, 300));
            // Refresh the modal to show updated data
            openEditOrdersModal();
          }
        } catch (error) {
          alert("Error updating price: " + error.message);
        }
      }

      function submitOrder() {
        if (cart.size === 0) {
          alert("Cart is empty.");
          return;
        }

        const items = Array.from(cart.values()).map((item) => ({
          productId: item.productId,
          quantity: item.quantity,
          price: item.price,
          name: item.name
        }));

        fetch("/orders", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items })
        }).then(() => {
          window.location.reload();
        });
      }



      // Category filtering
      let selectedCategory = "all";
      document.querySelectorAll(".category-btn").forEach((btn) => {
        btn.addEventListener("click", function() {
          selectedCategory = this.dataset.category;
          
          // Update button styles
          document.querySelectorAll(".category-btn").forEach(b => {
            if (b.dataset.category === selectedCategory) {
              b.classList.add("border-brand-500", "bg-brand-50", "text-brand-600");
              b.classList.remove("border-zinc-200", "bg-white", "text-zinc-900");
            } else {
              b.classList.remove("border-brand-500", "bg-brand-50", "text-brand-600");
              b.classList.add("border-zinc-200", "bg-white", "text-zinc-900");
            }
          });

          // Filter products
          document.querySelectorAll(".product-card").forEach((card) => {
            const category = card.dataset.productCategory || "General";
            if (selectedCategory === "all" || category === selectedCategory) {
              card.style.display = "";
            } else {
              card.style.display = "none";
            }
          });
        });
      });

      // Set initial active button
      const firstBtn = document.querySelector('.category-btn[data-category="all"]');
      if (firstBtn) {
        firstBtn.classList.add("border-brand-500", "bg-brand-50", "text-brand-600");
        firstBtn.classList.remove("border-zinc-200", "bg-white", "text-zinc-900");
      }

      renderCart();
    </script>
    <script src="/pwa-install.js"></script>
    <script>
      if (window.PWAInstall) {
        window.PWAInstall.bindInstallButton("#installPwaBtn");
      }
    </script>
  </body>
</html>