<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ea580c" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: "#fff7ed",
                100: "#ffedd5",
                500: "#f97316",
                600: "#ea580c"
              }
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-gradient-to-b from-white to-brand-50 text-zinc-800">
    <% const formatRP = (n) => `RP ${Number(n || 0).toLocaleString('en-US')}`; %>

    <header class="sticky top-0 z-20 border-b border-orange-100 bg-white/95 backdrop-blur">
      <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-4 md:px-6 md:py-5">
        <div>
          <h1 class="text-2xl font-extrabold text-brand-600">Online Store</h1>
          <p class="text-sm text-zinc-500">Welcome, <span class="font-bold"><%= user.name %></span></p>
        </div>
        <div class="flex items-center gap-2">
          <button id="installPwaBtn" type="button" class="hidden rounded-xl bg-brand-500 px-4 py-3 text-sm font-semibold text-white hover:bg-brand-600">
            Install App
          </button>
          <a href="/invoices-orders" class="rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700">📋 My Invoices</a>
          <% if (user.isAdmin) { %>
          <a href="/admin" class="rounded-xl border border-orange-200 px-4 py-3 text-sm font-semibold hover:bg-orange-50">Admin Panel</a>
          <% } %>
          <form method="post" action="/logout">
            <button class="rounded-xl bg-zinc-900 px-4 py-3 text-sm font-semibold text-white">Logout</button>
          </form>
        </div>
      </div>
    </header>

    <main class="mx-auto grid max-w-7xl gap-6 px-4 py-6 md:px-6 lg:grid-cols-12">
      <section class="space-y-4 lg:col-span-8 xl:col-span-9">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-xl font-bold">Products</h2>
          <input
            id="productSearch"
            type="search"
            placeholder="Search products..."
            class="w-full rounded-xl border border-orange-200 bg-white px-4 py-3 text-base outline-none ring-orange-200 transition focus:ring sm:w-80"
            oninput="filterProducts()"
          />
        </div>

        <div id="productsGrid" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          <% if (products.length === 0) { %>
          <div class="col-span-full rounded-2xl border border-dashed border-orange-200 bg-white p-8 text-center text-zinc-500">No products available yet.</div>
          <% } %>

          <% products.forEach((product) => { %>
          <article class="product-card rounded-2xl border border-orange-100 bg-white p-3 shadow-sm" data-name="<%= product.name.toLowerCase() %>">
            <img src="<%= product.image || '/default-product.svg' %>" alt="<%= product.name %>" class="h-48 w-full rounded-xl object-cover" />
            <div class="mt-3 space-y-3">
              <h3 class="text-lg font-bold"><%= product.name %></h3>
              <p class="text-lg font-extrabold text-brand-600"><%= formatRP(product.price) %></p>
              <div class="flex items-center justify-between gap-2">
                <input
                  id="qty-<%= product._id %>"
                  type="number"
                  min="0"
                  value="0"
                  class="w-24 rounded-xl border border-orange-200 px-3 py-3 text-center text-base"
                />
                <button
                  type="button"
                  onclick="addToCart('<%= product._id %>', '<%- product.name.replace(/'/g, "\\'") %>', <%= product.price %>)"
                  class="rounded-xl bg-brand-500 px-4 py-3 text-sm font-bold text-white hover:bg-brand-600"
                >
                  Add to Cart
                </button>
              </div>
            </div>
          </article>
          <% }) %>
        </div>
      </section>

      <aside class="space-y-4 lg:col-span-4 xl:col-span-3">
        <section class="rounded-2xl border border-orange-100 bg-white p-4 shadow-sm md:p-5">
          <h2 class="text-xl font-bold">Cart</h2>
          <div id="cartItems" class="mt-3 space-y-2 text-sm"></div>
          <div class="mt-3 border-t border-orange-100 pt-3">
            <p class="text-base font-bold">Total: <span id="cartTotal">RP 0</span></p>
          </div>
          <button onclick="submitOrder()" class="mt-4 w-full rounded-xl bg-brand-500 px-4 py-4 text-base font-bold text-white hover:bg-brand-600">
            Place Order
          </button>
        </section>

        <section class="rounded-2xl border border-orange-100 bg-white p-4 shadow-sm md:p-5">
          <div class="flex items-center justify-between gap-2">
            <h2 class="text-xl font-bold">Invoices & Orders</h2>
            <a href="/invoices-orders" class="rounded-lg border border-orange-200 px-3 py-2 text-xs font-semibold text-brand-600 hover:bg-orange-50">Open Details</a>
          </div>
          <div class="mt-3 space-y-2 text-sm">
            <% if (userOrders.length === 0) { %>
            <p class="text-zinc-500">No orders yet.</p>
            <% } %>
            <% userOrders.forEach((order) => { %>
            <div class="rounded-xl border border-orange-100 bg-orange-50/40 p-3">
              <p class="font-semibold">Invoice: <%= order.invoiceNumber %></p>
              <p>Status: <span class="font-bold <%= order.status === 'completed' ? 'text-emerald-600' : 'text-amber-600' %>"><%= order.status === "completed" ? "Completed" : "Pending" %></span></p>
              <p>Total: <%= formatRP(order.total) %></p>
              <a href="/invoices/<%= order.invoiceNumber %>" class="mt-2 inline-block text-sm font-semibold text-brand-600 hover:underline">View / Print Invoice</a>
            </div>
            <% }) %>
          </div>
        </section>
      </aside>
    </main>

    <% if (success) { %>
    <div class="fixed bottom-4 left-1/2 z-30 -translate-x-1/2 rounded-xl bg-zinc-900 px-4 py-3 text-sm font-semibold text-white"><%= success %></div>
    <% } %>

    <script>
      const cart = new Map();

      function formatRP(value) {
        return `RP ${Number(value || 0).toLocaleString("en-US")}`;
      }

      function addToCart(id, name, price) {
        const qtyInput = document.getElementById(`qty-${id}`);
        const qty = Number(qtyInput.value);
        if (!qty || qty <= 0) return;

        const existing = cart.get(id);
        if (existing) {
          existing.quantity += qty;
        } else {
          cart.set(id, { productId: id, name, price, quantity: qty });
        }

        qtyInput.value = 0;
        renderCart();
      }

      function renderCart() {
        const container = document.getElementById("cartItems");
        const totalEl = document.getElementById("cartTotal");
        container.innerHTML = "";
        let total = 0;

        for (const item of cart.values()) {
          const row = document.createElement("div");
          row.className = "flex items-center justify-between rounded-lg border border-orange-100 bg-orange-50/40 px-3 py-3";
          row.innerHTML = `
            <div>
              <p class="font-semibold">${item.name}</p>
              <p class="text-xs text-zinc-500">${item.quantity} x ${formatRP(item.price)}</p>
            </div>
            <button type="button" class="rounded-lg bg-red-50 px-3 py-2 text-xs font-semibold text-red-600" onclick="removeFromCart('${item.productId}')">Remove</button>
          `;
          container.appendChild(row);
          total += item.price * item.quantity;
        }

        if (cart.size === 0) {
          container.innerHTML = `<p class="text-zinc-500">Cart is empty.</p>`;
        }

        totalEl.textContent = formatRP(total);
      }

      function removeFromCart(id) {
        cart.delete(id);
        renderCart();
      }

      function submitOrder() {
        if (cart.size === 0) {
          alert("Cart is empty.");
          return;
        }

        const items = Array.from(cart.values()).map((item) => ({
          productId: item.productId,
          quantity: item.quantity
        }));

        fetch("/orders", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items })
        }).then(() => {
          window.location.reload();
        });
      }

      function filterProducts() {
        const query = document.getElementById("productSearch").value.trim().toLowerCase();
        const cards = document.querySelectorAll(".product-card");
        cards.forEach((card) => {
          const name = card.dataset.name || "";
          card.style.display = name.includes(query) ? "" : "none";
        });
      }

      renderCart();
    </script>
    <script src="/pwa-install.js"></script>
    <script>
      if (window.PWAInstall) {
        window.PWAInstall.bindInstallButton("#installPwaBtn");
      }
    </script>
  </body>
</html>
