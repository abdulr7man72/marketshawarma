<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: {
                50: "#fff7ed",
                100: "#ffedd5",
                500: "#f97316",
                600: "#ea580c",
              },
            },
          }, 
        },
      };
    </script>
  </head>
  <body class="min-h-screen bg-gradient-to-b from-white to-brand-50 text-zinc-800">
    <main class="mx-auto flex min-h-screen max-w-6xl items-center justify-center px-4 py-8">
      <div class="grid w-full items-center gap-8 rounded-3xl border border-orange-100 bg-white p-6 shadow-xl md:p-10 lg:grid-cols-2">
        <section class="space-y-4">
          <p class="inline-block rounded-full bg-brand-100 px-4 py-2 text-sm font-semibold text-brand-600">Simple Store</p>
          <h1 class="text-3xl font-extrabold leading-tight md:text-4xl">Sign in with your name only</h1>
          <p class="text-zinc-600">No password needed. Enter your name and start ordering.</p>
        </section>

        <section class="rounded-2xl border border-orange-100 bg-orange-50/40 p-6 md:p-8">
          <form method="post" action="/login" class="space-y-5">
            <label class="block space-y-2">
              <span class="text-base font-semibold text-zinc-700">Name</span>
              <input
                name="name"
                type="text"
                class="w-full rounded-xl border border-orange-200 bg-white px-4 py-4 text-base outline-none ring-orange-200 transition focus:ring"
                placeholder="Type your name"
                required
              />
            </label>

            <% if (error) { %>
            <div class="rounded-xl border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"><%= error %></div>
            <% } %>

            <button class="w-full rounded-xl bg-brand-500 px-4 py-4 text-base font-bold text-white transition hover:bg-brand-600">Sign In</button>
          </form>
        </section>
      </div>
    </main>
  </body>
</html>
